# Database Configuration
DATABASE_URL="postgresql://workshop:workshop123@localhost:5432/petcare?schema=public"

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Security
JWT_SECRET="petcare-secret-key-change-in-production"

# CORS Configuration - Lock down to specific origins
# For development: localhost on both 5173 (default) and 5174 (auto-switched)
# For production: your domain
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,https://yourdomain.com"

# Rate Limiting (optional - uses defaults if not set)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring
ENABLE_METRICS=true

# API Keys (optional - for future integrations)
# API_KEY="your-api-key-here"
